# Base image with Ubuntu 22.04
FROM ubuntu:22.04

# Set the working directory inside the container
WORKDIR /sniffles

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    libz-dev \
    make \
    bcftools \
    samtools \
    tabix \
    python3.10 \
    python3.10-distutils \
    python3-pip \
    zlib1g-dev \
    libcurl4-openssl-dev \
    libssl-dev \
    libhdf5-dev \ 
    libboost-all-dev \ 
    && rm -rf /var/lib/apt/lists/*

# Set Python 3.10 as the default python3
RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.10 1

# Upgrade pip to the latest version
RUN pip3 install --upgrade pip setuptools wheel

# Install required Python packages
RUN pip3 install --no-cache-dir sniffles pysam truvari edlib==1.3.9 psutil==5.9.4

# Verify installation of tools
RUN sniffles --help || echo "Sniffles installed successfully" && \
    truvari --help || echo "Truvari installed successfully" && \
    bcftools --version || echo "bcftools installed successfully" && \
    samtools --version || echo "Samtools installed successfully" && \
    tabix --version || echo "Tabix installed successfully" && \
    make --version || echo "Make installed successfully"

# Set the default command to keep the container running
CMD ["bash"]
