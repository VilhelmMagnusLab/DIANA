config {
    name = 'Test pipeline'
    workDir = 'work'
    launchDir = 'tests'
    projectDir = '..'
}

profiles {
    debug { process.beforeScript = 'echo $HOSTNAME' }
    conda { process.conda = "$projectDir/environment.yml" }
    docker { docker.enabled = true }
    apptainer { apptainer.enabled = true }
} 