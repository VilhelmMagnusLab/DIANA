configfile: "config/config.yaml"

include: "common.snakefile"
include: "basecall.snakefile"
include: "methylation.snakefile"
include: "figures.snakefile"
include: "SV.snakefile"

# target rules for batch classification

if 'batch_samples' in config.keys():
  rule batch_reports:
    input: expand("results/reports/{sample}_WGS_report_{{trainingset}}.pdf", sample=config['batch_samples'])
    output: "results/reports/batch_reports_{trainingset}.zip"
    shell: "zip {output} {input}"

  rule batch_calls:
    input: expand("results/classification/{sample}-votes-NN-{{trainingset}}.txt", sample=config['batch_samples'])
    output: "results/reports/batch_calls_{trainingset}.zip"
    shell: "zip {output} {input}"
