manifest {
    name            = 'nWGS_pipeline'
    author          = 'Christian D. Bope'
    homePage        = 'https://github.com/VilhelmMagnusLab/nWGS_pipeline'
    description     = 'Merge bam file from nanopore, epi2me(SV calling, modified base calling, CNV calling), analysis(MGMT, classifier (sturgeon, nanoDX), structure variant)'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=22.10.0'
    version         = '1.0dev'
}

params {
    // Pipeline options
    input    = null
    outdir   = './results'

    //run mode
    run_mode_epi2me = false
    run_mode_analysis = false
    run_mode_mergebam = false
    run_mode_order = false
    
    // Profile parameter
    profile = null
    
    // Default parameters
    max_cpus   = 16
    max_memory = '2.GB'
    max_time   = '240.h'

    // Set default work directory
    work_dir = "$projectDir/work"
    
    // Placeholder for nanodx_workflow_dir (will be overridden by analysis.config)
    nanodx_workflow_dir = null
}

// If run_mode_order is set, enable all valid modes
if (params.run_mode_order) {
    params.run_mode_mergebam = true
    params.run_mode_epi2me = 'all' 
    params.run_mode_analysis = 'rmd'
    
    // Force sequential execution when in order mode
    executor {
        queueSize = 1
    }
    
    // Add process dependencies
    process {
        withName: 'epi2me' {
            beforeScript = { task.attempt == 1 ? 'sleep 1' : '' }
            maxForks = 1
        }
        withName: 'analysis' {
            beforeScript = { task.attempt == 1 ? 'sleep 1' : '' }
            maxForks = 1
        }
    }
}

// Load config by default for all pipelines
if (params.run_mode_epi2me) {
    includeConfig 'conf/epi2me.config'
}

if (params.run_mode_analysis) {
    includeConfig 'conf/analysis.config'
}

if (params.run_mode_mergebam) {
    includeConfig 'conf/mergebam.config'
}

// Global Apptainer configuration
apptainer {
    enabled = true
    autoMounts = true
    runOptions = '--bind /home/ubuntu/data/images2 --bind /home/ubuntu/data'
}

// Add apptainer profile
// Profiles
profiles {
    // Apptainer for epi2me
    epi2me_auto_apptainer {
        process {
            executor = 'local'
        }
        apptainer {
            enabled = true
            autoMounts = true
            runOptions = '-B /home/ubuntu/data/images2 -B /home/ubuntu/'
        //    runOptions = "-B /home/ubuntu/miniconda3/envs/mut_env/bin:/usr/local/bin -B /home/ubuntu/"
            cacheDir = "apptainer-images"

        }
        env.PATH = "/home/ubuntu/miniconda3/envs/singularity_env/bin:$PATH"
        CURL_CA_BUNDLE = "/etc/ssl/certs/ca-certificates.crt" 
    }

    // Apptainer for analysis
    analysis_auto_apptainer {
        process {
            executor = 'local'
        }
        apptainer {
            enabled = true
            autoMounts = true
            runOptions = '-B /home/ubuntu/data/images2 -B /home/ubuntu/data'
            cacheDir = "apptainer-images"
        }
        //env {
        //    PATH = "/home/ubuntu/anaconda3/envs/mut_env/bin:$PATH"

        //}
    }

    // Apptainer for mergebam
    mergebam_auto_apptainer {
        process {
            executor = 'local'
        }
        apptainer {
            enabled = true
            autoMounts = true
            runOptions = "-B /home/ubuntu/data/images2 -B /home/ubuntu/"
            cacheDir = "apptainer-images"
        }
    }

    // Conda profile
    conda {
        process {
            conda.enabled = true
        }
    }
}

// Automatically apply Apptainer profiles
if (!params.profile) {
    if (params.run_mode_epi2me) {
        params.profile = 'epi2me_auto_apptainer'
    }
    if (params.run_mode_analysis) {
        params.profile = params.profile ? "${params.profile},analysis_auto_apptainer" : 'analysis_auto_apptainer'
    }
    if (params.run_mode_mergebam) {
        params.profile = params.profile ? "${params.profile},mergebam_auto_apptainer" : 'mergebam_auto_apptainer'
    }
}