manifest {
    name            = 'nWGS_pipeline'
    author          = 'Christian Domilongo Bope, Skarphéðinn Halldórsson and Richard Nagymihaly'
    homePage        = 'https://github.com/VilhelmMagnusLab/nWGS_pipeline'
    description     = 'A comprehensive bioinformatics pipeline for analyzing Central Nervous System (CNS) samples using Oxford Nanopore sequencing data. Integrates multiple analyses including CNV detection, methylation profiling, structural variant calling, and MGMT promoter status determination.'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.10.1'
    version         = '1.0.0'
    license         = 'MIT'
}

params {
    // Pipeline options
    input    = null
    outdir   = './results'

    //run mode
    run_mode_epi2me = false
    run_mode_analysis = false
    run_mode_mergebam = false
    run_mode_order = false
    run_mode_epianalyse = false
    
    // Profile parameter
    profile = null
    
    // Default parameters
    max_cpus   = 16
    max_memory = '2.GB'
    max_time   = '240.h'

    // Set default work directory
    work_dir = "$projectDir/work"
    
    // Placeholder for nanodx_workflow_dir (will be overridden by analysis.config)
    nanodx_workflow_dir = null
}

// If run_mode_order is set, enable all valid modes
if (params.run_mode_order) {
    params.run_mode_mergebam = true
    params.run_mode_epi2me = 'all' 
    // Note: run_mode_analysis is set to 'all' in main.nf when run_mode_order is true
    
    // Force sequential execution when in order mode
    executor {
        queueSize = 1
    }
    
    // Add process dependencies
    process {
        withName: 'epi2me' {
            beforeScript = { task.attempt == 1 ? 'sleep 1' : '' }
            maxForks = 1
        }
        withName: 'analysis' {
            beforeScript = { task.attempt == 1 ? 'sleep 1' : '' }
            maxForks = 1
        }
    }
}

// Load config by default for all pipelines
if (params.run_mode_order) {
    // For run_mode_order, load analysis.config first to ensure all parameters are set
    includeConfig 'conf/analysis.config'
    if (params.run_mode_epi2me) {
        includeConfig 'conf/epi2me.config'
    }
    if (params.run_mode_mergebam) {
        includeConfig 'conf/mergebam.config'
    }
} else if (params.run_mode_epianalyse) {
    // For run_mode_epianalyse, load epi2me and analysis configs
    includeConfig 'conf/epi2me.config'
    includeConfig 'conf/analysis.config'
} else {
    // For individual modes, load configs normally
    if (params.run_mode_epi2me) {
        includeConfig 'conf/epi2me.config'
    }
    if (params.run_mode_analysis) {
        includeConfig 'conf/analysis.config'
    }
    if (params.run_mode_mergebam) {
        includeConfig 'conf/mergebam.config'
    }
}

// Global Apptainer/Singularity configuration
apptainer {
    enabled = true
    autoMounts = false
    // Note: Nextflow may still add automatic bind mounts, but we try to minimize them
    // Remove R environment clearing for run_mode_order, run_mode_epianalyse and tsne_plot to avoid breaking R-dependent processes
    runOptions = (params.run_mode_order || params.run_mode_epianalyse || params.run_mode_analysis == 'rmd') ?
        '--bind /home/chbope/extension/nWGS_manuscript_data:/home/chbope/extension/nWGS_manuscript_data --bind /home/chbope/Documents/nanopore/nWGS_manuscript/nWGS_pipeline_docker_test:/home/chbope/Documents/nanopore/nWGS_manuscript/nWGS_pipeline_docker_test --bind /home/chbope/extension/trash:/home/chbope/extension/trash' :
        '--bind /home/chbope/extension/nWGS_manuscript_data:/home/chbope/extension/nWGS_manuscript_data --bind /home/chbope/Documents/nanopore/nWGS_manuscript/nWGS_pipeline_docker_test:/home/chbope/Documents/nanopore/nWGS_manuscript/nWGS_pipeline_docker_test --bind /home/chbope/extension/trash:/home/chbope/extension/trash --env R_LIBS_USER="" --env R_LIBS_SITE="" --env R_USER_CACHE_DIR="" --env R_PROFILE_USER="" --env R_ENVIRON_USER=""'
}

// Profiles for different container systems
profiles {
    // Apptainer/Singularity for epi2me
    epi2me_auto_apptainer {
        process {
            executor = 'local'
        }
        apptainer {
            enabled = true
            autoMounts = false
            runOptions = '--bind /home/chbope/extension/nWGS_manuscript_data:/home/chbope/extension/nWGS_manuscript_data --bind /home/chbope/Documents/nanopore/nWGS_manuscript/nWGS_pipeline_docker_test:/home/chbope/Documents/nanopore/nWGS_manuscript/nWGS_pipeline_docker_test --bind /home/chbope/extension/trash:/home/chbope/extension/trash --env R_LIBS_USER="" --env R_LIBS_SITE="" --env R_USER_CACHE_DIR="" --env R_PROFILE_USER="" --env R_ENVIRON_USER=""'
            cacheDir = "containers"
        }
    }

    // Apptainer/Singularity for analysis
    analysis_auto_apptainer {
        process {
            executor = 'local'
        }
        apptainer {
            enabled = true
            autoMounts = false
            runOptions = '--bind /home/chbope/extension/nWGS_manuscript_data:/home/chbope/extension/nWGS_manuscript_data --bind /home/chbope/Documents/nanopore/nWGS_manuscript/nWGS_pipeline_docker_test:/home/chbope/Documents/nanopore/nWGS_manuscript/nWGS_pipeline_docker_test --bind /home/chbope/extension/trash:/home/chbope/extension/trash --env R_LIBS_USER="" --env R_LIBS_SITE="" --env R_USER_CACHE_DIR="" --env R_PROFILE_USER="" --env R_ENVIRON_USER=""'
            cacheDir = "containers"
        }
    }

    // Apptainer/Singularity for mergebam
    mergebam_auto_apptainer {
        process {
            executor = 'local'
        }

    // The PATH /home/chbope/extension/nWGS_manuscript_data/data:/data : Need to be replace by the user projectDir
    // The PATH /home/chbope/Documents/nanopore/nWGS_manuscript/nWGS_pipeline_docker_test/ Need to be replace by the user pipeline path where the container folder will be created
        apptainer {
            enabled = true
            autoMounts = false
            runOptions = '--bind /home/chbope/extension/nWGS_manuscript_data:/home/chbope/extension/nWGS_manuscript_data --bind /home/chbope/Documents/nanopore/nWGS_manuscript/nWGS_pipeline_docker_test:/home/chbope/Documents/nanopore/nWGS_manuscript/nWGS_pipeline_docker_test --bind /home/chbope/extension/trash:/home/chbope/extension/trash --env R_LIBS_USER="" --env R_LIBS_SITE="" --env R_USER_CACHE_DIR="" --env R_PROFILE_USER="" --env R_ENVIRON_USER=""'
            cacheDir = "containers"
        }
    }

    // Docker profile
    docker {
        docker {
            enabled = true
            runOptions = '-v ${projectDir}/data:${projectDir}/data'
        }
    }

    // Conda profile
    conda {
        process {
            conda.enabled = true
        }
    }
}

// Automatically apply Apptainer/Singularity profiles
// Temporarily disabled to allow log generation
/*
if (!params.profile) {
    if (params.run_mode_epi2me) {
        params.profile = 'epi2me_auto_apptainer'
    }
    if (params.run_mode_analysis) {
        params.profile = params.profile ? "${params.profile},analysis_auto_apptainer" : 'analysis_auto_apptainer'
    }
    if (params.run_mode_mergebam) {
        params.profile = params.profile ? "${params.profile},mergebam_auto_apptainer" : 'mergebam_auto_apptainer'
    }
}
*/

// Force log generation for all runs - simplified configuration
trace {
    enabled = true
}

report {
    enabled = true
    overwrite = true
    file = "${params.work_dir}/execution_report.html"
}

timeline {
    enabled = true
    overwrite = true
    file = "${params.work_dir}/execution_timeline.html"
}