manifest {
    name            = 'nWGS_pipeline'
    author          = 'Christian Domilongo Bope, Skarphéðinn Halldórsson and Richard Nagymihaly'
    homePage        = 'https://github.com/VilhelmMagnusLab/nWGS_pipeline'
    description     = 'A comprehensive bioinformatics pipeline for analyzing Central Nervous System (CNS) samples using Oxford Nanopore sequencing data. Integrates multiple analyses including CNV detection, methylation profiling, structural variant calling, and MGMT promoter status determination.'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.10.1'
    version         = '1.0.1'
    license         = 'MIT'
}

params {
    // Pipeline options
    input    = null
    outdir   = './results'

    //run mode
    run_mode_epi2me = false
    run_mode_annotation = false
    run_mode_mergebam = false
    run_mode_order = false
    run_mode_epiannotation = false
    
    // Profile parameter
    profile = null
    
    // Default parameters
    max_cpus   = 16
    max_memory = '2.GB'
    max_time   = '240.h'

    // Set default work directory
    work_dir = "$projectDir/work"
    
    // Placeholder for nanodx_workflow_dir (will be overridden by annotation.config)
    nanodx_workflow_dir = null
}

// If run_mode_order is set, enable all valid modes
if (params.run_mode_order) {
    params.run_mode_mergebam = true
    params.run_mode_epi2me = 'all'
    // Note: run_mode_annotation is set to 'all' in main.nf when run_mode_order is true

    // Sequential execution is ensured through channel dependencies in main.nf
    // No need for executor queueSize or process-level controls
}

// Load config by default for all pipelines
if (params.run_mode_order) {
    // For run_mode_order, load annotation.config first to ensure all parameters are set
    includeConfig 'conf/annotation.config'
    if (params.run_mode_epi2me) {
        includeConfig 'conf/epi2me.config'
    }
    if (params.run_mode_mergebam) {
        includeConfig 'conf/mergebam.config'
    }
} else if (params.run_mode_epiannotation) {
    // For run_mode_epiannotation, load epi2me and analysis configs
    includeConfig 'conf/epi2me.config'
    includeConfig 'conf/annotation.config'
} else {
    // For individual modes, load configs normally
    if (params.run_mode_epi2me) {
        includeConfig 'conf/epi2me.config'
    }
    if (params.run_mode_annotation) {
        includeConfig 'conf/annotation.config'
    }
    if (params.run_mode_mergebam) {
        includeConfig 'conf/mergebam.config'
    }
}

// Global Apptainer/Singularity configuration
apptainer {
    enabled = true
    autoMounts = false
    // Note: Nextflow may still add automatic bind mounts, but we try to minimize them
    // Remove R environment clearing for run_mode_order, run_mode_epiannotation and tsne_plot to avoid breaking R-dependent processes
    runOptions = (params.run_mode_order || params.run_mode_epiannotation || params.run_mode_annotation == 'rmd') ?
        '--bind /home/godzilla:/home/godzilla --bind /data:/data' :
        '--bind /home/godzilla:/home/godzilla --bind /data:/data --env R_LIBS_USER="" --env R_LIBS_SITE="" --env R_USER_CACHE_DIR="" --env R_PROFILE_USER="" --env R_ENVIRON_USER=""'
}

// Profiles for different container systems
profiles {
    // Apptainer/Singularity for epi2me
    epi2me_auto_apptainer {
        process {
            executor = 'local'
        }
        apptainer {
            enabled = true
            autoMounts = false
            //runOptions = '--bind /data/routine_nWGS_pipeline/nWGS_pipeline:/data/routine_nWGS_pipeline/nWGS_pipeline --env R_LIBS_USER="" --env R_LIBS_SITE="" --env R_USER_CACHE_DIR="" --env R_PROFILE_USER="" --env R_ENVIRON_USER=""'
            runOptions = '--bind /data:/data --env R_LIBS_USER="" --env R_LIBS_SITE="" --env R_USER_CACHE_DIR="" --env R_PROFILE_USER="" --env R_ENVIRON_USER=""'

            cacheDir = "containers"
        }
    }

    // Apptainer/Singularity for analysis
    annotation_auto_apptainer {
        process {
            executor = 'local'
        }
        apptainer {
            enabled = true
            autoMounts = false
            //runOptions = '--bind  /data/routine_nWGS_pipeline/nWGS_pipeline:/data/routine_nWGS_pipeline/nWGS_pipeline --env R_LIBS_USER="" --env R_LIBS_SITE="" --env R_USER_CACHE_DIR="" --env R_PROFILE_USER="" --env R_ENVIRON_USER=""'
            runOptions = '--bind /data:/data --env R_LIBS_USER="" --env R_LIBS_SITE="" --env R_USER_CACHE_DIR="" --env R_PROFILE_USER="" --env R_ENVIRON_USER=""'

            cacheDir = "containers"
        }
    }

    // Apptainer/Singularity for mergebam
    mergebam_auto_apptainer {
        process {
            executor = 'local'
        }

    // The PATH /home/chbope/extension/nWGS_manuscript_data/data:/data : Need to be replace by the user projectDir
    // The PATH /home/chbope/Documents/nanopore/nWGS_manuscript/nWGS_pipeline_docker_test/ Need to be replace by the user pipeline path where the container folder will be created
        apptainer {
            enabled = true
            autoMounts = false
            runOptions = '--bind /data:/data --env R_LIBS_USER="" --env R_LIBS_SITE="" --env R_USER_CACHE_DIR="" --env R_PROFILE_USER="" --env R_ENVIRON_USER=""'
            
            cacheDir = "containers"
        }
    }

    // Docker profile
    docker {
        docker {
            enabled = true
            runOptions = '-v ${projectDir}/data:${projectDir}/data'
        }
    }

    // Conda profile
    conda {
        process {
            conda.enabled = true
        }
    }
}

// Automatically apply Apptainer/Singularity profiles
// Temporarily disabled to allow log generation
/*
if (!params.profile) {
    if (params.run_mode_epi2me) {
        params.profile = 'epi2me_auto_apptainer'
    }
    if (params.run_mode_annotation) {
        params.profile = params.profile ? "${params.profile},annotation_auto_apptainer" : 'annotation_auto_apptainer'
    }
    if (params.run_mode_mergebam) {
        params.profile = params.profile ? "${params.profile},mergebam_auto_apptainer" : 'mergebam_auto_apptainer'
    }
}
*/

// Force log generation for all runs - simplified configuration
// Generate a session identifier based on run mode and sample info
// Using workflow.sessionId ensures consistency when using -resume
def getLogPrefix() {
    def mode = params.run_mode_epiannotation ? 'epiannotation' :
               params.run_mode_order ? 'order' :
               params.run_mode_epi2me ? 'epi2me' :
               params.run_mode_annotation ? 'annotation' :
               params.run_mode_mergebam ? 'mergebam' : 'unknown'

    // Try to get sample IDs from the appropriate file
    def sampleInfo = ""
    try {
        def sampleFile = null
        if (params.run_mode_epi2me || params.run_mode_epiannotation || params.run_mode_order) {
            sampleFile = params.epi2me_sample_id_file ?: "${params.path}/sample_ids.txt"
        } else if (params.run_mode_annotation) {
            sampleFile = params.analyse_sample_id_file ?: "${params.path}/sample_ids.txt"
        } else if (params.run_mode_mergebam) {
            sampleFile = params.bam_sample_id_file ?: "${params.path_output}/sample_ids_bam.txt"
        }

        if (sampleFile && new File(sampleFile).exists()) {
            def samples = new File(sampleFile).readLines().findAll { it.trim() && !it.startsWith('#') }
            if (samples.size() > 0) {
                // For single sample, use the ID; for multiple, use count
                sampleInfo = samples.size() == 1 ? "_${samples[0]}" : "_${samples.size()}samples"
            }
        }
    } catch (Exception e) {
        // If sample file doesn't exist yet, just use mode
        sampleInfo = ""
    }

    // Use timestamp for initial identification
    def timestamp = new java.util.Date().format('yyyyMMdd-HHmmss')
    return "${mode}${sampleInfo}_${timestamp}"
}

trace {
    enabled = true
    // Trace files with timestamp - new file each run (even with -resume)
    file = "logs/trace-${getLogPrefix()}.txt"
    overwrite = false
}

report {
    enabled = true
    // Report with mode and sample ID - creates new file each run
    file = "logs/execution_report-${getLogPrefix()}.html"
    overwrite = false
}

timeline {
    enabled = true
    // Timeline with mode and sample ID - creates new file each run
    file = "logs/execution_timeline-${getLogPrefix()}.html"
    overwrite = false
}
