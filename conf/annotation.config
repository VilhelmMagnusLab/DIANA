/*
 * ============================================================================
 * nWGS Pipeline - Annotation Configuration
 * ============================================================================
 *
 * IMPORTANT: PATH CONFIGURATION REQUIREMENTS
 * ==========================================
 *
 * Before running this pipeline, you MUST update the following paths to match
 * your system configuration:
 *
 * 1. BASE PATH (CRITICAL):
 *    - Update 'params.path' to point to your data directory
 *    - This is the root directory containing all your data folders
 *
 * 2. nWGS PIPELINE DIRECTORY:
 *    - Update 'params.nWGS_dir' to point to your nWGS pipeline installation
 *    - This should be the directory containing this config file
 *
 * 3. REFERENCE FILES:
 *    - Ensure all reference files exist in the specified paths
 *    - Check that file names match exactly (case-sensitive)
 * 
 * 4. ANNOTATION DATABASES:
 *    - Verify humandb directory contains required annotation files
 *    - Download missing databases if needed
 * 
 * 5. TOOL PATHS:
 *    - svanna_bin_dir: Points to bin/ folder containing svanna-cli-1.0.4.jar
 *    - svanna_dir: Points to reference/ folder containing svanna-data/
 * 
 * EXAMPLE CONFIGURATION:
 * =====================
 * If your data is in /home/user/nwgs_data and pipeline is in /opt/nWGS_pipeline:
 * 
 * params {
 *     path = "/home/user/nwgs_data"
 *     nWGS_dir = "/opt/nWGS_pipeline"
 *     // ... other settings
 * }
 * 
 * REQUIRED DIRECTORY STRUCTURE:
 * ============================
 * /your_data_path/
 * ├── reference/           # Reference files and databases
 * │   ├── svanna-data/     # Svanna annotation database
 * │   ├── nanoDx/          # NanoDx models and workflows
 * │   └── *.fa, *.bed, etc # Other reference files
 * ├── humandb/             # Annotation databases
 * │   ├── hg38_refGene.txt
 * │   ├── hg38_clinvar_*.txt
 * │   └── hg38_cosmic*.txt
 * └── results/             # Output directory (created automatically)
 * 
 * VALIDATION CHECKLIST:
 * ====================
 * params.path points to your data directory
 * params.nWGS_dir points to pipeline installation
 * All reference files exist in reference/ directory
 * Annotation databases exist in humandb/ directory
 * svanna-cli-1.0.4.jar exists in bin/ directory
 * svanna-data/ directory exists in reference/ directory
 * Sample IDs file exists in testdata/ directory
 * 
 * ============================================================================
 */

params {
    // Pipeline mode parameters
    run_mode_order = false
    
    // ============================================================================
    // CRITICAL: UPDATE THESE PATHS TO MATCH YOUR SYSTEM
    // ============================================================================

    // Base data path - UPDATE THIS TO YOUR DATA DIRECTORY
    path = "/home/godzilla/routine_nWGS"

    // nWGS pipeline installation directory - UPDATE THIS TO YOUR PIPELINE LOCATION
    nWGS_dir = "/home/godzilla/nWGS_pipeline"


    // ============================================================================
    // DERIVED PATHS (automatically calculated from base paths above)
    // ============================================================================

    // Input/Output paths
    input_path = "${params.path}"
    output_path = "${params.path}"  // Base output path (shared with epi2me)
    result_path = "${params.path}/routine_results"
    
    // Reference and annotation directories
    ref_dir = "${params.nWGS_dir}/data/reference"
    humandb_dir = "${params.nWGS_dir}/data/humandb"

    
    // ============================================================================
    // REFERENCE FILES (must exist in reference/ directory)
    // ============================================================================
    // These files are required for genome annotation. Ensure they exist and are properly indexed.
    reference_genome = "${params.ref_dir}/GCF_000001405.39_GRCh38.p13_genomic_chr_only_plus_mt.fa"
    reference_genome_bai = "${params.ref_dir}/GCF_000001405.39_GRCh38.p13_genomic_chr_only_plus_mt.fa.fai"
    ncbirefseq = "${params.ref_dir}/ncbiRefSeq.txt.gz"
    
    // Analysis-specific reference files (ROI, EPIC, MGMT, TERTp analysis)
    // These files contain genomic regions and variants specific to the annotation
    epicsites = "${params.ref_dir}/EPIC_sites_NEW.bed"
    mgmt_cpg_island_hg38 = "${params.ref_dir}/MGMT_CpG_Island.hg38.bed"
    tertp_variants = "${params.ref_dir}/TERTp_variants.bed"
    tr_bed_file = "${params.ref_dir}/human_GRCh38_trf.bed"
    genecode_bed = "${params.ref_dir}/gencode.v48.annotation.gff3"
    roi_protein_coding_bed = "${params.ref_dir}/roi.protein_coding.bed"
    gviz_data = "${params.ref_dir}/Gviz.RData"
    cytoband_file = "${params.ref_dir}/cytoBandIdeo.hg38.txt"
    snv_target_genes = "${params.ref_dir}/snv_target_genes.txt"
    cnv_genes_tuned = "${params.ref_dir}/CNV_genes_tuned.csv"

    // SNV filtering thresholds
    snv_depth_threshold = 10    // Minimum depth for SNV filtering (default: 10)
    snv_gq_threshold = 10       // Minimum Genotype Quality threshold (variants with ANY GQ value >= this threshold will be kept)

    // ============================================================================
    // ANNOTATION DATABASES (must exist in humandb/ directory)
    // ============================================================================
    // These databases are used for variant annotation. Download from ANNOVAR if missing.
    refgene = "${params.humandb_dir}/hg38_refGene.txt"
    hg38_refgenemrna = "${params.humandb_dir}/hg38_refGeneMrna.fa"
    clinvar = "${params.humandb_dir}/hg38_clinvar_20240611.txt"
    clinvarindex = "${params.humandb_dir}/hg38_clinvar_20240611.txt.idx"
    hg38_cosmic100 = "${params.humandb_dir}/hg38_cosmic100coding2024.txt"
    hg38_cosmic100index = "${params.humandb_dir}/hg38_cosmic100coding2024.txt.idx"
    
    
    // ============================================================================
    // NANODX CONFIGURATION (neural network classification)
    // ============================================================================
    // NanoDx requires specific model files and workflows for tumor classification
    // By default uses Capper et al. classifier (brain tumors)
    // To use pan-cancer classifier, add flag: --pancan
    pancan = false

    model_path = "${params.path}/testdata"
    hg19_450model = "${params.ref_dir}/nanoDx/static/hg19_450model.bed"
    nanodx_450model = params.pancan ? "${params.ref_dir}/nanoDx/static/pancan_devel_v5i_NN.pkl" : "${params.ref_dir}/nanoDx/static/Capper_et_al_NN.pkl"
    nanodx_dictinaire = params.pancan ? "${params.ref_dir}/nanoDx/static/pancan_devel_v5i_dictionary.txt" : "${params.ref_dir}/nanoDx/static/Capper_et_al_dictionary.txt"
    nanodxcolormap = params.pancan ? "${params.ref_dir}/nanoDx/static/colorMap_pancan_devel_v5i.txt" : "${params.ref_dir}/nanoDx/static/colorMap_Capper_et_al.txt"
    nanodxh5 = params.pancan ? "${params.ref_dir}/nanoDx/static/pancan_devel_v5i.h5" : "${params.ref_dir}/nanoDx/static/Capper_et_al.h5"
    nn_model = "${params.ref_dir}/nanoDx/workflow/envs/NN_model.yaml"
    snakefile_nanodx = "${params.ref_dir}/nanoDx/workflow/Snakefile"
    nanodx_workflow_dir = "${params.ref_dir}/nanoDx/workflow"
    occ_fusion_genes_list = "${params.ref_dir}/occ_fusions_genes.txt"
    occ_genes = "${params.ref_dir}/OCCgenes.rds"
    params.sturgeon_model = "${params.ref_dir}/general.zip"
    
    // ============================================================================
    // TOOL PATHS AND CONFIGURATIONS
    // ============================================================================
    

    
    // Svanna structural variant annotation
    svanna_dir = "${params.ref_dir}"                    // Directory containing svanna-data/
    svanna_bin_dir = "${params.nWGS_dir}/bin"          // Directory containing svanna-cli-1.0.4.jar
    vcf2circos_json = "${params.ref_dir}/options.json" // Circos plot configuration

    // ClairS-TO model reference (for structural variant calling)
    clairsto_models = '${params.path}/reference/r1041_e82_400bps_sup_v420'

    // Ensembl VEP cache directory (must contain GRCh38 cache, e.g., homo_sapiens/109_GRCh38)
    vep_cache_dir = "${params.ref_dir}/vep_cache"
    
    // ============================================================================
    // INPUT/OUTPUT DIRECTORY CONFIGURATION
    // ============================================================================
    
    // Input data configuration
    analyse_sample_id_file = params.run_mode_order ? null : "${params.path}/sample_ids.txt"

    // ROI BAM folder - keep reference here for annotation workflow compatibility
    // Primary configuration is in epi2me.config
    roi_bam_folder = "${params.path}/routine_bams/roi_bams"
    ///roi_bam_folder = "/home/godzilla/africa/angola/P24_WGS_analysis/Benchmarking/1hr/roi"

    merge_bam_folder = "${params.path}/routine_bams/merge_bams"
    ///merge_bam_folder = "/home/godzilla/africa/congordc/Prospective_WGS/routine_bams/merge_bams"

    // Epi2me output directories (created automatically)
    sv_folder = "${params.path}/routine_epi2me"
    bedmethyl_folder = "${params.path}/routine_epi2me"
    segsfromepi2me_folder = "${params.path}/routine_epi2me"
    cnv_rds = "${params.path}/routine_epi2me"
    
    // ============================================================================
    // REPORT CONFIGURATION
    // ============================================================================
    
    // Report generation files
    mardown_logo = "${params.ref_dir}/log_update.pdf"
    
    // ============================================================================
    // t-SNE/UMAP DIMENSIONALITY REDUCTION CONFIGURATION
    // ============================================================================
    
    
    // NanoDx methylation classification parameters
    //nanodxcolormap = "${params.ref_dir}/nanoDx/static/colorMap_Capper_et_al.txt"
    //nanodxh5 = "${params.ref_dir}/nanoDx/static/Capper_et_al2.h5"

}

process {
    // Default settings for all processes
    executor = 'local'
    container = "${params.nWGS_dir}/containers/nwgs_default_images_latest.sif"
    // container = 'vilhelmmagnuslab/nwgs_default_images:latest'  // Docker version
    
    // Process-specific settings
    withName: 'ace_tmc' {
        container = "${params.nWGS_dir}/containers/ace_1.24.0_latest.sif"
        // container = 'vilhelmmagnuslab/ace_1.24.0:latest'  // Docker version
        cpus = 4
        memory = '8 GB'
    }
    
    withName: 'annotatecnv' {
        container = "${params.nWGS_dir}/containers/annotcnv_images_27feb1025_latest.sif"
        // container = 'vilhelmmagnuslab/annotcnv_images_27feb1025:latest'  // Docker version
        cpus = 4
        memory = '8 GB'
    }
    
    withName: 'clair3_annotate' {
        container = "${params.nWGS_dir}/containers/nwgs_default_images_latest.sif"
        // container = 'vilhelmmagnuslab/clair3_amd64:latest'  // Docker version
        cpus = 4
        memory = '8 GB'
    }

    withName: 'clairs_to_annotate' {
        // Use default container which has all annotation tools including tabix, bcftools, and ANNOVAR
        container = "${params.nWGS_dir}/containers/nwgs_default_images_latest.sif"
        // container = 'vilhelmmagnuslab/nwgs_default_images:latest'  // Docker version
        cpus = 4
        memory = '8 GB'
    }

    withName: 'igv_tools' {
        container = "${params.nWGS_dir}/containers/igv_report_amd64_latest.sif"
        // container = 'vilhelmmagnuslab/igv_report_amd64:latest'  // Docker version
        cpus = 4
        memory = '8 GB'
    }

    withName: 'circosplot' {
        container = "${params.nWGS_dir}/containers/vcf2circos_latest.sif"
        // container = 'vilhelmmagnuslab/vcf2circos:latest'  // Docker version
        // Bind mount the correct options.json to override container's default
        containerOptions = "--bind ${params.ref_dir}/options.json:/Static/options.json"
        cpus = 4
        memory = '8 GB'
    }

    withName: 'crossNN' {
        container = "${params.nWGS_dir}/containers/nanodx_images_3feb25_latest.sif"
        // container = 'vilhelmmagnuslab/nanodx_images_3feb25:latest'  // Docker version
        cpus = 4
        memory = '8 GB'
    }

    withName: 'markdown_report' {
        container = "${params.nWGS_dir}/containers/markdown_images_28feb2025_latest.sif"
        // container = 'vilhelmmagnuslab/markdown_images_28feb2025:latest'  // Docker version
        cpus = 4
        memory = '8 GB'
    }

    // cramino_report moved to epi2me workflow - see epi2me.config

    withName: 'plot_genomic_regions' {
        container = "${params.nWGS_dir}/containers/gviz_amd64ps_latest.sif"
        // container = 'vilhelmmagnuslab/gviz_amd64:latest'  // Docker version
        cpus = 4
        memory = '8 GB'
    }

    withName: 'svannasv_fusion_events' {
        container = "${params.nWGS_dir}/containers/nwgs_default_images_latest.sif"
        // container = 'vilhelmmagnuslab/nwgs_default_images:latest'  // Docker version
        cpus = 4
        memory = '8 GB'
    }

    withName: 'extract_epic' {
           container = "${params.nWGS_dir}/containers/nwgs_default_images_latest.sif"
        // container = 'vilhelmmagnuslab/nwgs_default_images:latest'  // Docker version
        cpus = 4
        memory = '8 GB'
    }

    withName: 'nanodx' {
        container = "${params.nWGS_dir}/containers/nwgs_default_images_latest.sif"
        // container = 'vilhelmmagnuslab/nwgs_default_images:latest'  // Docker version
        cpus = 4
        memory = '8 GB'
    }

    withName: 'mgmt_promoter' {
            container = "${params.nWGS_dir}/containers/nwgs_default_images_latest.sif"
        // container = 'vilhelmmagnuslab/nwgs_default_images:latest'  // Docker version
        cpus = 4
        memory = '8 GB'
    }

    withName: 'svannasv' {
           container = "${params.nWGS_dir}/containers/nwgs_default_images_latest.sif"
        // container = 'vilhelmmagnuslab/nwgs_default_images:latest'  // Docker version
        cpus = 4
        memory = '8 GB'
    }

    withName: 'merge_annotation' {
    container = "${params.nWGS_dir}/containers/nwgs_default_images_latest.sif"
        // container = 'vilhelmmagnuslab/nwgs_default_images:latest'  // Docker version
        cpus = 4
        memory = '8 GB'
    }

    withName: 'tsne_plot' {
        container = "${params.nWGS_dir}/containers/crossnnumap_latest.sif"
        // container = '"${params.path}/containers/crossnnumap_latest.sif"
        cpus = 8
        memory = '75 GB'  // 
        // Override container options to ensure conda environment is available and R env is not cleared
        //containerOptions = '--bind /data/routine_nWGS'
    }

    withName:sturgeon {
        container = "${params.nWGS_dir}/containers/sturgeon_amd64_21jan_latest.sif"
        cpus = 4
        memory = '8 GB'
        // Override container options to ensure Python virtual environment works correctly
        containerOptions = '--bind /home/godzilla:/home/godzilla --bind /data:/data'
    }
       
}

// Apptainer configuration for Singularity/Apptainer containers
// Note: Apptainer is enabled globally in nextflow.config, commenting out to avoid override
// apptainer {
//     enabled = false
//     autoMounts = true
//     runOptions = '--bind /home/godzilla/routine_nWGS'
//     //runOptions = '--bind /home/chbope/extension/nWGS_manuscript_data/data:/data --bind /home/chbope/test_pipeline/nWGS_pipeline_docker_test/containers:/containers'
// }

// Docker configuration (commented out for Singularity/Apptainer compatibility)
// docker {
//     enabled = true
//     runOptions = '-v /home/chbope/extension/nWGS_manuscript_data/data:/home/chbope/extension/nWGS_manuscript_data/data'
// }

conda {
    enabled = true
}
