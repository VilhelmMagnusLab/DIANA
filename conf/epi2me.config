/*
 * ============================================================================
 * nWGS Pipeline - Epi2me Configuration
 * ============================================================================
 * 
 * IMPORTANT: Epi2me PATH CONFIGURATION REQUIREMENTS
 * =================================================
 * 
 * This configuration file is specifically for the Epi2me module analysis including:
 * - Structural Variant (SV) calling with Sniffles2
 * - Copy Number Variant (CNV) analysis with QDNAseq
 * - Modified base calling with Modkit
 * 
 * Before running this pipeline, you MUST update the following paths to match
 * your system configuration:
 * 
 * 1. BASE PATH (CRITICAL):
 *    - Update 'params.path' to point to your data directory
 *    - This is the root directory containing all your data folders
 * 
 * 2. REFERENCE FILES:
 *    - Ensure reference genome files exist in reference/ directory
 *    - Check that file names match exactly (case-sensitive)
 * 
 * 3. INPUT DATA:
 *    - Verify merged BAM files exist in the specified merge_bam_folder
 *    - Ensure sample_ids.txt contains valid sample identifiers
 * 
 * 4. OUTPUT DIRECTORIES:
 *    - Epi2me results will be organized in results/epi2me/ subdirectories
 *    - Directories are created automatically if they don't exist
 * 
 * EXAMPLE CONFIGURATION:
 * =====================
 * If your data is in /home/user/nwgs_data:
 * 
 * params {
 *     path = "/home/user/nwgs_data"
 *     // ... other settings will be automatically calculated
 * }
 * 
 * REQUIRED DIRECTORY STRUCTURE FOR Epi2me:
 * ========================================
 * /your_data_path/
 * ├── reference/                    # Reference files
 * │   ├── GRCh38.fa
 * │   └── GRCh38.fa.fai
 * ├── testdata/                     # Input data
 * │   ├── sample_ids.txt           # Sample IDs file (one per line)
 * │   └── single_bam_folder/       # BAM file organization
 * │       └── merge_bam/           # Merged BAM files from previous step
 * └── results/                      # Output directory (created automatically)
 *     └── epi2me/                  # Epi2me-specific results
 *         ├── episv/               # Structural variant results
 *         ├── modkit/              # Modified base calling results
 *         └── epicnv/              # Copy number variant results
 * 
 * Epi2me ANALYSIS COMPONENTS:
 * ==========================
 * 
 * 1. STRUCTURAL VARIANT CALLING (Sniffles2):
 *    - Input: Merged BAM files
 *    - Output: VCF files with structural variants
 *    - Parameters: min_sv_length, min_read_support, cluster_merge_pos
 * 
 * 2. COPY NUMBER VARIANT ANALYSIS (QDNAseq):
 *    - Input: Merged BAM files
 *    - Output: CNV segments and bins
 *    - Parameters: binsize (in kb)
 * 
 * 3. MODIFIED BASE CALLING (Modkit):
 *    - Input: Merged BAM files
 *    - Output: Methylation data in bedmethyl format
 *    - Parameters: interval_size, modkit_threads
 * 
 * VALIDATION CHECKLIST FOR Epi2me:
 * ================================
 * params.path points to your data directory
 * Reference genome files exist in reference/ directory
 * Merged BAM files exist in testdata/single_bam_folder/merge_bam/
 * Sample IDs file exists in testdata/sample_ids.txt
 * Sample IDs in file match BAM file names
 * BAM files are properly indexed (.bai files exist)
 * Sufficient disk space for Epi2me output (typically 2-5x input size)
 * 
 * ============================================================================
 */

params {
    // ============================================================================
    // CRITICAL: UPDATE THIS PATH TO MATCH YOUR SYSTEM
    // ============================================================================
    
    // Base data path - UPDATE THIS TO YOUR DATA DIRECTORY
    path = "/home/godzilla/nWGS_pipeline/data"
    output_path ="/home/godzilla/routine_nWGS"
    
    // nWGS pipeline installation directory - UPDATE THIS TO YOUR PIPELINE LOCATION
    nWGS_dir = "/home/godzilla/nWGS_pipeline"
    
    // ============================================================================
    // Epi2me OUTPUT DIRECTORY CONFIGURATION
    // ============================================================================
    // These directories will be created automatically if they don't exist
    episv = "${output_path}/routine_epi2me"        // Structural variant results
    epimodkit = "${output_path}/routine_epi2me"   // Modified base calling results
    epicnv = "${output_path}/routine_epi2me"      // Copy number variant results
    
    // ============================================================================
    // REFERENCE FILES (must exist in reference/ directory)
    // ============================================================================
    // These files are required for Epi2me analysis. Ensure they exist and are indexed.
    reference_genome = "${path}/reference/GCF_000001405.39_GRCh38.p13_genomic_chr_only_plus_mt.fa"
    reference_genome_bai = "${path}/reference/GCF_000001405.39_GRCh38.p13_genomic_chr_only_plus_mt.fa.fai"
    
    // ============================================================================
    // INPUT DATA CONFIGURATION
    // ============================================================================
    // Input paths for Epi2me analysis. This is the default path 
    ///merge_bam_folder = "${output_path}/routine_bams/merge_bams"  // This automatic path generated by mergebam run. Merged BAM files from previous step

    merge_bam_folder = "/home/godzilla/africa/angola/P24_WGS_analysis/Benchmarking/1hr"  //This path is manually provided for a particular run where the bam file is located
    epi2me_sample_id_file = "${output_path}/sample_ids.txt"          // Sample IDs file
 
    ///merge_bam_folder = "/home/chbope/extension/nWGS_manuscript_data/data/testdata/single_bam_folder/merge_bam"  // Merged BAM files from previous step
    ///epi2me_sample_id_file = "/home/chbope/extension/nWGS_manuscript_data/data/testdata/sample_ids.txt" 
    // ============================================================================
    // Epi2me ANALYSIS PARAMETERS
    // ============================================================================
    // These parameters control the behavior of Epi2me analysis tools
    
    // QDNAseq parameters (CNV analysis)
    binsize = 50                    // Bin size in kb for CNV analysis (default: 50)
    
    // Modkit parameters (modified base calling)
    interval_size = 100000          // Interval size for methylation analysis (default: 100kb)
    modkit_threads = 1              // Number of threads for Modkit (increase for faster processing)
    
    // Sniffles2 parameters (structural variant calling)
    min_sv_length = 30              // Minimum SV length in bp (default: 30)
    min_read_support = "auto"       // Minimum read support for SVs ("auto" or number)
    cluster_merge_pos = 150         // SV cluster merge position in bp (default: 150)
}

// ============================================================================
// Epi2me LABS CONFIGURATION
// ============================================================================
// Metadata for Epi2me platform integration
epi2melabs {
    tags = "human,variant calling,whole genome"
    icon = "faIdCard"
}


// ============================================================================
// PROCESS CONFIGURATION (Container and Resource Settings)
// ============================================================================
// These settings control which containers are used and resource allocation
// Uncomment Docker containers and comment Singularity containers if using Docker

process {
    // Structural Variant calling with Sniffles2
    withName: run_epi2me_sv {
        container = "${params.nWGS_dir}/containers/snifflesv252_update_latest.sif"
        // container = 'vilhelmmagnuslab/snifflesv252_update_latest:latest'  // Docker version
        cpus = 4
        memory = '5 GB'
    }

    // Copy Number Variant analysis with QDNAseq
    withName: run_epi2me_cnv {
        container = "${params.nWGS_dir}/containers/qdnaseq_amd64_latest.sif"
        // container = 'vilhelmmagnuslab/qdnaseq_amd64_latest:latest'  // Docker version
        // Bind empty directory over host R library path to prevent host library conflicts
        containerOptions = "--bind /home/godzilla/nWGS_pipeline/.empty_r_overlay:/home/godzilla/R"
        cpus = 4
        memory = '5 GB'
    }

    // Modified base calling with Modkit
    withName: run_epi2me_modkit {
        container = "${params.nWGS_dir}/containers/modkit_latest.sif"
        // container = 'vilhelmmagnuslab/modkit_latest:latest'  // Docker version
        cpus = 4
        memory = '5 GB'
    }
}

// ============================================================================
// CONTAINER ENGINE CONFIGURATION
// ============================================================================
// Choose between Singularity/Apptainer or Docker by enabling the appropriate section

// Singularity/Apptainer configuration (currently enabled)
// Note: Apptainer is enabled globally in nextflow.config, so we don't need to enable it here
// Commenting out to avoid "Cannot enable more than one container engine" error
// apptainer {
//     autoMounts = true
//     runOptions = '--bind /data:/data'
// }

// Docker configuration (uncomment to use Docker instead of Singularity/Apptainer)
// docker {
//     enabled = true
//     runOptions = '-v /home/chbope/extension/nWGS_manuscript_data/data:/home/chbope/extension/nWGS_manuscript_data/data'
// }

// ============================================================================
// ENVIRONMENT VARIABLES
// ============================================================================
// These environment variables control the behavior of Epi2me tools

env {
    // Uncomment and modify these paths if you need to use specific conda environments
    // PATH = "/home/ubuntu/.conda/envs/singularity_env/bin:$PATH"
    // PATH = "/home/ubuntu/miniconda3/envs/mut_env/bin:$PATH"
    
    // Python environment settings
    PYTHONNOUSERSITE = 1              // Prevent Python from using user site packages
    
    // Java settings for QDNAseq
    JAVA_TOOL_OPTIONS = "-Xlog:disable -Xlog:all=warning:stderr"  // Reduce Java logging verbosity
    
    // Rust settings for Modkit
    RUST_BACKTRACE = 1                // Enable Rust backtraces for debugging
}
