// Example configuration for nWGS pipeline with Docker
// Copy this file and modify the paths for your data

params {
    // ========================================
    // USER CONFIGURATION - MODIFY THESE PATHS
    // ========================================
    
    // Base paths - CHANGE THESE TO YOUR PATHS
    path = "/path/to/your/data"                    // Change this to your data directory
    input_path = "${params.path}"
    output_path = "${params.path}/results"
    ref_dir = "${params.path}/reference"          // Your reference files directory
    humandb_dir = "${params.path}/humandb"        // Your annotation databases directory
    
    // ========================================
    // REFERENCE FILES - ENSURE THESE EXIST
    // ========================================
    
    // Reference genome files
    reference_genome = "${params.ref_dir}/GCF_000001405.39_GRCh38.p13_genomic_chr_only_plus_mt.fa"
    reference_genome_bai = "${params.ref_dir}/GCF_000001405.39_GRCh38.p13_genomic_chr_only_plus_mt.fa.fai"
    ncbirefseq = "${params.ref_dir}/ncbiRefSeq.txt.gz"
    
    // Analysis-specific reference files
    occ_fusions = "${params.ref_dir}/OCC.fusions.bed"
    epicsites = "${params.ref_dir}/EPIC_sites_NEW.bed"
    mgmt_cpg_island_hg38 = "${params.ref_dir}/MGMT_CpG_Island.hg38.bed"
    roi_protein_coding_bed = "${params.ref_dir}/OCC.protein_coding.bed"
    tertp_variants = "${params.ref_dir}/TERTp_variants.bed"
    tr_bed_file = "${params.ref_dir}/human_GRCh38_trf.bed"
    genecode_bed = "${params.ref_dir}/gencode.v48.annotation.gff3"
    gviz_data = "${params.ref_dir}/Gviz.RData"
    cytoband_file = "${params.ref_dir}/cytoBandIdeo.hg38.txt"
    
    // Annotation files
    refgene = "${params.humandb_dir}/hg38_refGene.txt"
    hg38_refgenemrna = "${params.humandb_dir}/hg38_refGeneMrna.fa"
    clinvar = "${params.humandb_dir}/hg38_clinvar_20240611.txt"
    clinvarindex = "${params.humandb_dir}/hg38_clinvar_20240611.txt.idx"
    hg38_cosmic100 = "${params.humandb_dir}/hg38_cosmic100coding2024.txt"
    hg38_cosmic100index = "${params.humandb_dir}/hg38_cosmic100coding2024.txt.idx"
    
    // Configuration files
    vcf2circos_json = "${params.ref_dir}/options.json"
    
    // ========================================
    // INPUT DATA - MODIFY FOR YOUR SAMPLES
    // ========================================
    
    // Sample IDs file - CREATE THIS FILE WITH YOUR SAMPLE NAMES
    analyse_sample_id_file = "${params.path}/testdata/sample_ids.txt"
    
    // Input directories
    roi_bam_folder = "${params.path}/testdata/single_bam_folder/occ_bam"
    merge_bam_folder = "${params.path}/testdata/bams"  // Your BAM files directory
    
    // ========================================
    // OUTPUT DIRECTORIES - THESE WILL BE CREATED
    // ========================================
    
    sv_folder = "${params.path}/results/epi2me/episv"
    bedmethyl_folder = "${params.path}/results/epi2me/modkit"
    segsfromepi2me_folder = "${params.path}/results/epi2me/epicnv"
    cnv_rds = "${params.path}/results/epi2me/epicnv"
    
    // ========================================
    // MODEL FILES - ENSURE THESE EXIST
    // ========================================
    
    model_path = "${params.path}/testdata"
    hg19_450model = "${params.ref_dir}/nanoDx/static/hg19_450model.bed"
    nanodx_450model = "${params.ref_dir}/nanoDx/static/Capper_et_al_NN.pkl"
    nanodx_dictinaire = "${params.ref_dir}/nanoDx/static/Capper_et_al_dictionary.txt"
    nn_model = "${params.ref_dir}/nanoDx/workflow/envs/NN_model.yaml"
    snakefile_nanodx = "${params.ref_dir}/nanoDx/workflow/Snakefile"
    occ_fusion_genes_list = "${params.ref_dir}/occ_fusions_genes.txt"
    occ_genes = "${params.ref_dir}/OCCgenes.rds"
    
    // ========================================
    // TOOL DIRECTORIES - MODIFY IF NEEDED
    // ========================================
    
    svanna_dir = "${params.path}/bin"
    bin_dir = "${params.svanna_dir}"
    clairsto_models = "${params.path}/reference/r1041_e82_400bps_sup_v420"
    nanodx_workflow_dir = "${params.ref_dir}/nanoDx/workflow"
    
    // ========================================
    // REPORT FILES - OPTIONAL
    // ========================================
    
    mardown_logo = "${params.path}/log_update.pdf"  // Optional: your logo for reports
}

// Docker configuration - NO CHANGES NEEDED
process {
    // Default settings for all processes
    executor = 'local'
    container = 'vilhelmmagnuslab/nwgs_default_images:latest'
    
    // Process-specific settings
    withName: 'ace_tmc' {
        container = 'vilhelmmagnuslab/ace_1.24.0:latest'
        cpus = 1
        memory = '1 GB'
    }
    
    withName: 'annotatecnv' {
        container = 'vilhelmmagnuslab/annotcnv_images_27feb1025:latest'
        cpus = 4
        memory = '2 GB'
    }
    
    withName: 'clairs_to' {
        container = 'vilhelmmagnuslab/clair3_amd64:latest'
        cpus = 4
        memory = '2 GB'
    }
    
    withName: 'clair3' {
        container = 'vilhelmmagnuslab/clair3_amd64:latest'
        cpus = 4
        memory = '3 GB'
    }

    withName: 'igv_tools' {
        container = 'vilhelmmagnuslab/igv_report_amd64:latest'
        cpus = 1
        memory = '1 GB'
    }

    withName: 'circosplot' {
        container = 'vilhelmmagnuslab/vcf2circos:latest'
        cpus = 2
        memory = '2 GB'
    }

    withName: 'crossNN' {
        container = 'vilhelmmagnuslab/nanodx_images_3feb25:latest'
        cpus = 2
        memory = '1 GB'
    }

    withName: 'markdown_report' {
        container = 'vilhelmmagnuslab/markdown_images_28feb2025:latest'
        cpus = 1
        memory = '1 GB'
    }

    withName: 'cramino_report' {
        container = 'vilhelmmagnuslab/mgmt_nanopipe_amd64_18feb2025_cramoni:latest'
        cpus = 1
        memory = '1 GB'
    }

    withName: 'plot_genomic_regions' {
        container = 'vilhelmmagnuslab/gviz_amd64:latest'
        cpus = 2
        memory = '1 GB'
    }

    withName: 'svannasv_fusion_events' {
        container = 'vilhelmmagnuslab/nwgs_default_images:latest'
        cpus = 2
        memory = '1 GB'
    }

    withName: 'extract_epic' {
        cpus = 2
        memory = '2 GB'
    }

    withName: 'nanodx' {
        cpus = 2
        memory = '2 GB'
    }

    withName: 'mgmt_promoter' {
        cpus = 4
        memory = '2 GB'
    }

    withName: 'svannasv' {
        cpus = 1
        memory = '1 GB'
    }

    withName: 'merge_annotation' {
        cpus = 1
        memory = '1 GB'
    }
}

docker {
    enabled = true
    runOptions = '-v /path/to/your/data:/path/to/your/data'  // CHANGE THIS PATH
}

conda {
    enabled = true
} 