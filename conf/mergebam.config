/*
 * ============================================================================
 * nWGS Pipeline - Mergebam Configuration
 * ============================================================================
 * 
 * IMPORTANT: Mergebam PATH CONFIGURATION REQUIREMENTS
 * ===================================================
 * 
 * This configuration file is specifically for the Mergebam module, which performs
 * BAM merging from multiple single BAM from nanopore ONT file processing including:
 * - Merging multiple BAM files per sample
 * - Extracting Regions of Interest (ROI) from merged BAM files
 * - Preparing data for downstream analysis (Epi2me and Analysis modules)
 * 
 * Before running this pipeline, you MUST update the following paths to match
 * your system configuration:
 * 
 * 1. BASE PATH (CRITICAL):
 *    - Update 'params.path' to point to your data directory
 *    - This is the root directory containing all your data folders
 * 
 * 2. INPUT DATA STRUCTURE:
 *    - Verify BAM files are organized in Sample_ID folders
 *    - Ensure sample_ids_bam.txt contains valid sample identifiers
 *    - Check that BAM files are properly indexed (.bai files)
 * 
 * 3. REFERENCE FILES:
 *    - Ensure ROI BED file exists in reference/ directory
 *    - Verify file names match exactly (case-sensitive)
 * 
 * 4. OUTPUT DIRECTORIES:
 *    - Merged BAM files will be stored in single_bam_folder/merge_bam/
 *    - ROI BAM files will be stored in single_bam_folder/occ_bam/
 *    - Directories are created automatically if they don't exist
 * 
 * EXAMPLE CONFIGURATION:
 * =====================
 * If your data is in /home/user/nwgs_data:
 * 
 * params {
 *     path = "/home/user/nwgs_data"
 *     // ... other settings will be automatically calculated
 * }
 * 
 * REQUIRED DIRECTORY STRUCTURE FOR Mergebam:
 * ==========================================
 * /your_data_path/
 * ├── reference/                    # Reference files
 * │   └── OCC.protein_coding.bed   # Regions of Interest BED file
 * ├── testdata/                     # Input data
 * │   ├── sample_ids_bam.txt       # Sample IDs file (one per line)
 * │   └── Sample_ID_1/             # Sample-specific folders
 * │       ├── sample1_run1.bam     # BAM files for this sample
 * │       ├── sample1_run1.bai     # BAM index files
 * │       ├── sample1_run2.bam
 * │       └── sample1_run2.bai
 * │   └── Sample_ID_2/             # Another sample folder
 * │       ├── sample2_run1.bam
 * │       └── sample2_run1.bai
 * └── results/                      # Output directory (created automatically)
 *     └── single_bam_folder/       # Processed BAM files
 *         ├── merge_bam/           # Merged BAM files (one per sample)
 *         └── occ_bam/             # ROI-extracted BAM files
 * 
 * Mergebam PROCESSING STEPS:
 * =========================
 * 
 * 1. BAM FILE MERGING:
 *    - Input: Multiple BAM files per sample in Sample_ID folders
 *    - Output: Single merged BAM file per sample
 *    - Tool: Samtools merge
 *    - Parameters: threads (number of processing threads)
 * 
 * 2. REGIONS OF INTEREST EXTRACTION:
 *    - Input: Merged BAM files
 *    - Output: ROI-specific BAM files
 *    - Tool: Samtools view with BED file filtering
 *    - Parameters: roi_bed (BED file defining regions of interest)
 * 
 * 3. DATA ORGANIZATION:
 *    - Creates standardized directory structure
 *    - Prepares data for downstream analysis modules
 *    - Ensures consistent file naming and organization
 * 
 * VALIDATION CHECKLIST FOR Mergebam:
 * ==================================
 * params.path points to your data directory
 * ROI BED file exists in reference/ directory
 * Sample IDs file exists in testdata/sample_ids_bam.txt
 * Sample ID folders exist in testdata/ directory
 * BAM files exist in each Sample_ID folder
 * BAM index files (.bai) exist for each BAM file
 * Sample IDs in file match folder names exactly
 * Sufficient disk space for merged BAM files (typically 1.5-2x input size)
 * ============================================================================
 */

params {
    // ============================================================================
    // CRITICAL: UPDATE THIS PATH TO MATCH YOUR SYSTEM
    // ============================================================================
    
    // Base data path - UPDATE THIS TO YOUR DATA DIRECTORY
    path = "/home/godzilla/nWGS_pipeline/data"
    path_output ="/home/godzilla/routine_nWGS"
    nWGS_dir = "/home/godzilla/nWGS_pipeline"

    // ============================================================================
    // INPUT/OUTPUT DIRECTORY CONFIGURATION
    // ============================================================================
    // These paths define where input data is located and where output will be stored
    
    // Input directory containing Sample_ID folders with BAM files
    input_dir      = "/home/godzilla/WGS_Dummy"
  // Base directory containing Sample_ID folders
    
    // Output directories for processed BAM files
    merge_bam_dir  = "${params.path_output}/routine_bams/merge_bams" // Directory to store merged BAM files
    occ_bam_dir    = "${params.path_output}/routine_bams/roi_bams"   // Directory to store ROI-extracted BAM files
    
    // ============================================================================
    // PROCESSING PARAMETERS
    // ============================================================================
    // These parameters control the behavior of BAM processing tools
    
    // Resource allocation
    threads        = 16  // Number of threads for samtools operations (increase for faster processing)
    
    // Reference files
    roi_bed        = "${params.path}/reference/roi.protein_coding.bed"  // Regions of Interest BED file
    
    // Sample configuration
    bam_sample_id_file = "${params.path_output}/sample_ids_bam.txt"   // Sample IDs file for BAM processing
}

// ============================================================================
// PROCESS CONFIGURATION (Container and Resource Settings)
// ============================================================================
// These settings control which containers are used and resource allocation for BAM processing

process {
    executor = 'local'

    // BAM file merging process
    withName: 'merge_bam_files' {
        container = "${params.nWGS_dir}/containers/nwgs_default_images_latest.sif"
        cpus = 16
        memory = '24 GB'
        // Bind mount entire home directory to avoid permission issues
        containerOptions = '--bind /home/godzilla:/home/godzilla --no-home'
    }

    // Regions of Interest extraction process
    withName: 'extract_roi' {
        container = "${params.nWGS_dir}/containers/nwgs_default_images_latest.sif"
        cpus = 16
        memory = '24 GB'
        // Bind mount entire home directory to avoid permission issues
        containerOptions = '--bind /home/godzilla:/home/godzilla --no-home'
    }
}

// ============================================================================
// CONTAINER ENGINE CONFIGURATION
// ============================================================================
// Singularity/Apptainer configuration for BAM processing containers

apptainer {
    enabled = false
    autoMounts = true
    runOptions = "--no-sandbox"
    envWhitelist = []
}

// ============================================================================
// CONDA ENVIRONMENT CONFIGURATION
// ============================================================================
// Conda environment settings for additional tools

conda {
    enabled = true
}

// ============================================================================
// ENVIRONMENT VARIABLES
// ============================================================================
// These environment variables control the behavior of BAM processing tools

env {
    // System PATH configuration
    PATH = "/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:$PATH"
    
    // Python environment settings
    PYTHONNOUSERSITE = 1              // Prevent Python from using user site packages
}


