params {
    path = "/home/chbope/extension"

    input_dir      = "${params.path}/data/testdata"  // Base directory containing Sample_ID folders
    merge_bam_dir  = "${params.path}/testdata/single_bam_folder/merge_bam" // Directory to store merged BAM files
    occ_bam_dir    = "${params.path}/testdata/single_bam_folder/occ_bam"
    threads        = 12  // Number of threads for samtools operations
    roi_bed        = "${params.path}/data/reference/OCC.protein_coding.bed"
    bam_sample_id_file = "${params.path}/data/testdata/sample_ids_bam.txt"
}

process {
    executor = 'local'

    withName: 'merge_bam_files' {
        container = '/home/chbope/extension/images/mgmt_nanopipe_amd64_26spet_jdk_igv_python_plotly_latest.sif'
        cpus = 12
        memory = '12 GB'
        containerOptions = '--bind /home/chbope/extension --no-home'
    }

    withName: 'extract_roi' {
        container = '/home/chbope/extension/images/mgmt_nanopipe_amd64_26spet_jdk_igv_python_plotly_latest.sif'
        cpus = 12
        memory = '12 GB'
        containerOptions = '--bind /home/chbope/extension --no-home'
    }
}

singularity {
    enabled = true
    autoMounts = true
    runOptions = "-B /home/chbope/extension --no-home"
}

conda {
    enabled = true
}
